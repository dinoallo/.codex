# Track only user-maintained Codex configuration by default.
*

!.gitignore
!AGENTS.md
!README.md
!README.*.md
!prompts/
!prompts/**
!scripts/
!scripts/**
!skills/
!skills/**

# Keep script runtime byproducts out of the tracked config set.
scripts/**/__pycache__/
scripts/**/*.pyc

# Ignore bundled/system skills shipped with Codex itself.
skills/.system/

# Ignore local infrastructure helper state and generated Proxmox stack outputs.
skills/infra/.tools/
skills/infra/.venv/
skills/infra/**/.artifacts/
skills/infra/**/.terraform/
skills/infra/**/terraform.tfstate
skills/infra/**/terraform.tfstate.*
skills/infra/**/tf.vars
skills/infra/**/*.tfvars
skills/infra/**/*.tfvars.json

# Ignore local auth, state, logs, caches, and session data.
.personality_migration
.tmp/
auth.json
config.toml
history.jsonl
log/
logs_*.sqlite
logs_*.sqlite-*
memories/
sessions/
shell_snapshots/
state_*.sqlite
state_*.sqlite-*
tmp/
version.json

# Optional: keep sanitized examples if you add them later.
!*.example.toml
